@app.route("/image")
def serve_image():
    """Serves the local image file to be displayed as a thumbnail in the UI."""
    file_path = request.args.get("path")
    if not file_path or not os.path.exists(file_path):
        return "Image not found", 404
    return send_file(file_path)



@app.route("/api/search", methods=["POST"])
def search():
    data = request.json
    keywords = data.get("keywords", [])
    filter_tags = data.get("tags", [])
    start_date = data.get("start_date")
    end_date = data.get("end_date")
    limit = min(int(data.get("limit", default_limit)), 100) # Cap at 100

    if not keywords and not filter_tags and not start_date and not end_date:
         return jsonify({"error": "Please provide keywords for vector search or use filters."}), 400

    if len(keywords) > 5:
        return jsonify({"error": "Maximum 5 keywords allowed for vector search."}), 400

    try:
        conn = get_db_connection()
        cur = conn.cursor()

        binds = {}
        where_clauses = ["1=1"]
        
        # Base SELECT columns
        cols = "p.file_path, p.caption, p.tags_json"
        
        if keywords:
            embed_text = " ".join(keywords)
            vec = get_embedding(embed_text)
            if vec is None:
                return jsonify({"error": "Failed to generate embeddings via Ollama. Check if Ollama is running."}), 500
            
            binds["vec"] = vec
            cols += ", VECTOR_DISTANCE(p.embedding, :vec, COSINE) as dist"
            order_by = " ORDER BY dist ASC "
        else:
            cols += ", 0 as dist"
            order_by = " ORDER BY p.created_ts DESC "

        # Add exact JSON tags filter
        if filter_tags:
            for tag in filter_tags:
                tag_clean = tag.replace('"', '\\"')
                # Use JSON_EXISTS with literal value exactly like q1.sql
                where_clauses.append(f"json_exists(p.tags_json, '$?(@ == \"{tag_clean}\")')")

        # Add date range filters
        if start_date:
            binds["start_date"] = start_date + " 00:00:00"
            where_clauses.append("p.created_ts >= TO_TIMESTAMP(:start_date, 'YYYY-MM-DD HH24:MI:SS')")
        if end_date:
            binds["end_date"] = end_date + " 23:59:59"
            where_clauses.append("p.created_ts <= TO_TIMESTAMP(:end_date, 'YYYY-MM-DD HH24:MI:SS')")

        where_sql = " AND ".join(where_clauses)
        sql = f"SELECT {cols} FROM photo_ai p WHERE {where_sql} {order_by} FETCH FIRST {limit} ROWS ONLY"
        
        cur.execute(sql, binds)
        rows = cur.fetchall()
        
        results = []
        for row in rows:
            tags_data = []
            if row[2]:
                try:
                    raw_tags = row[2].read() if hasattr(row[2], 'read') else row[2]
                    if isinstance(raw_tags, str):
                        tags_data = json.loads(raw_tags)
                    else:
                        tags_data = raw_tags
                except Exception as e:
                    print("Error parsing JSON tags:", e)
                    tags_data = []
            
            caption_val = row[1].read() if hasattr(row[1], 'read') else row[1]
            
            results.append({
                "file_path": row[0],
                "caption": caption_val,
                "tags": tags_data,
                "distance": row[3]
            })

        return jsonify({"results": results})
    except Exception as e:
        import traceback
        traceback.print_exc()
        return jsonify({"error": str(e)}), 500

def main():
    parser = argparse.ArgumentParser(description="Run the Photo Match Display AI App")
    parser.add_argument("--host", required=True, help="Oracle DB Host")
    parser.add_argument("--port", required=True, help="Oracle DB Port")
    parser.add_argument("--username", required=True, help="Oracle DB Username")
    parser.add_argument("--password", required=True, help="Oracle DB Password")
    parser.add_argument("--dbname", required=True, help="Oracle DB Name (Service or SID)")
    parser.add_argument("--ollama-host", default=os.environ.get("OLLAMA_HOST", "http://localhost:11434"), help="Ollama Host URL")
    parser.add_argument("--embed-model", default=os.environ.get("EMBED_MODEL", "mxbai-embed-large"), help="Embedding model name")
    parser.add_argument("--web-port", type=int, default=5000, help="Port to run the web server on")
    parser.add_argument("--limit", type=int, default=10, help="Default number of photos to return (max 100)")

    args = parser.parse_args()

    # Assign globals
    global db_config, ollama_host, embed_model, tags_list, default_limit
    db_config = {
        "host": args.host,
        "port": args.port,
        "username": args.username,
        "password": args.password,
        "dbname": args.dbname
    }
    ollama_host = args.ollama_host
    embed_model = args.embed_model
    default_limit = min(args.limit, 100) # Cap at 100

    print("Loading tags from tag-count.txt...", end=" ")
    tags_list = load_tags()
    print(f"Loaded {len(tags_list)} unique tags.")

    print(f"Starting web server on http://localhost:{args.web_port}")
    # Disable flask output to keep CLI clean
    logging.getLogger('werkzeug').setLevel(logging.ERROR)
    app.run(host="0.0.0.0", port=args.web_port, debug=False)

if __name__ == "__main__":
    main()
