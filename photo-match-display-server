def load_tags():
    tags = []
    if os.path.exists("tag-count.txt"):
        with open("tag-count.txt", "r", encoding="utf-8") as f:
            for line in f:
                if len(line) >= 40:
                    tag = line[:40].strip()
                    if tag:
                        tags.append(tag)
                else:
                    parts = line.split()
                    if parts:
                        tags.append(" ".join(parts[:-1]))
    return sorted(list(set(tags)))

def get_embedding(text):
    payload = {"model": embed_model, "input": text}
    try:
        r = requests.post(f"{ollama_host}/api/embed", json=payload, timeout=60)
        r.raise_for_status()
        vec = r.json()["embeddings"][0]
        return array("f", vec)
    except Exception as e:
        print(f"Error getting embedding: {e}")
        return None

def get_db_connection():
    dsn = f"{db_config['host']}:{db_config['port']}/{db_config['dbname']}"
    return oracledb.connect(
        user=db_config['username'],
        password=db_config['password'],
        dsn=dsn
    )

