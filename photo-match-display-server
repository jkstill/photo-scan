#!/usr/bin/env python3 

import argparse
import os
import json
import array
from flask import Flask, request, jsonify, render_template, send_file
import oracledb
import requests

app = Flask(__name__)

# Global configuration state
config = {}

def get_db_connection():
    dsn = f"{config['host']}:{config['port']}/{config['dbname']}"
    return oracledb.connect(user=config['username'], password=config['password'], dsn=dsn)

@app.route('/')
def index():
    return render_template('index.html', default_limit=config.get('limit', 10))

@app.route('/api/tags')
def get_tags():
    try:
        with get_db_connection() as conn:
            with conn.cursor() as cur:
                # Retrieve all unique tags for autocomplete
                cur.execute("""
                    select distinct jt.tag
                    from photo_ai p, json_table(p.tags_json, '$[*]' columns (tag varchar2(100) path '$')) jt
                    where jt.tag is not null 
                    order by 1
                """)
                tags = [row[0] for row in cur.fetchall()]
        return jsonify(tags)
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/api/search', methods=['POST'])
def search():
    data = request.json
    keywords = data.get('keywords', [])
    filter_tags = data.get('filter_tags', [])
    start_date = data.get('start_date')
    end_date = data.get('end_date')
    include_null_date = data.get('include_null_date', True)
    
    # Retrieve limit from frontend, fallback to server default
    try:
        req_limit = int(data.get('limit', config['limit']))
    except ValueError:
        req_limit = config['limit']
    
    if not keywords:
        return jsonify({"error": "At least one keyword is required for vector search"}), 400
        
    search_text = " ".join(keywords)
    
    # Generate Embedding via Ollama
    try:
        r = requests.post(f"{config['ollama_host']}/api/embed", json={"model": config['embed_model'], "input": search_text})
        r.raise_for_status()
        vector = r.json()["embeddings"][0]
        vector_array = array.array("f", vector)
    except Exception as e:
        return jsonify({"error": f"Ollama embedding failed: {str(e)}"}), 500

    try:
        with get_db_connection() as conn:
            with conn.cursor() as cur:
                query = """
                    SELECT photo_id, file_path, caption, tags_json, exif_json, exif_date_original,
                           VECTOR_DISTANCE(embedding, :vec, COSINE) as dist
                    FROM photo_ai
                    WHERE 1=1
                """
                params = {"vec": vector_array}
                
                # Tag filtering (Exact Match)
                if filter_tags:
                    for i, tag in enumerate(filter_tags):
                        param_name = f"tag_{i}"
                        query += f" AND json_exists(tags_json, '$?(@ == $T)' PASSING :{param_name} AS \"T\")"
                        params[param_name] = tag

                # Date filtering
                if start_date and end_date:
                    date_clause = "(exif_date_original >= to_timestamp(:start_date, 'YYYY-MM-DD HH24:MI:SS') AND exif_date_original <= to_timestamp(:end_date, 'YYYY-MM-DD HH24:MI:SS'))"
                    params["start_date"] = f"{start_date} 00:00:00"
                    params["end_date"] = f"{end_date} 23:59:59"
                    
                    if include_null_date:
                        query += f" AND ({date_clause} OR exif_date_original IS NULL)"
                    else:
                        query += f" AND {date_clause}"
                elif not include_null_date:
                     query += " AND exif_date_original IS NOT NULL"
                    
                query += " ORDER BY dist FETCH FIRST :req_limit ROWS ONLY"
                params["req_limit"] = req_limit
                
                cur.execute(query, params)
                
                results = []
                for row in cur.fetchall():
                    caption_clob = row[2]
                    caption = caption_clob.read() if caption_clob else ""
                    results.append({
                        "photo_id": row[0],
                        "file_path": row[1],
                        "caption": caption,
                        "tags": row[3] if row[3] else [],
                        "exif": row[4] if row[4] else [],
                        "date": row[5].strftime("%Y-%m-%d %H:%M:%S") if row[5] else None,
                        "distance": round(row[6], 4)
                    })
        return jsonify(results)
    except Exception as e:
        return jsonify({"error": str(e)}), 500

@app.route('/image')
def get_image():
    path = request.args.get('path')
    if not path or not os.path.exists(path):
        return "Image not found", 404
    return send_file(path)

def main():
    parser = argparse.ArgumentParser(description="Run the Photo Match Display AI App")
    parser.add_argument("--host", required=True, help="Oracle DB Host")
    parser.add_argument("--port", required=True, help="Oracle DB Port")
    parser.add_argument("--username", required=True, help="Oracle DB Username")
    parser.add_argument("--password", required=True, help="Oracle DB Password")
    parser.add_argument("--dbname", required=True, help="Oracle DB Name (Service or SID)")
    parser.add_argument("--ollama-host", default=os.environ.get("OLLAMA_HOST", "http://localhost:11434"), help="Ollama Host URL")
    parser.add_argument("--embed-model", default=os.environ.get("EMBED_MODEL", "mxbai-embed-large"), help="Embedding model name")
    parser.add_argument("--web-port", type=int, default=5000, help="Port to run the web server on")
    parser.add_argument("--limit", type=int, default=10, help="Default number of photos to return (max 100)")

    args = parser.parse_args()

    # Assign globals
    global config
    config = {
        "host": args.host,
        "port": args.port,
        "username": args.username,
        "password": args.password,
        "dbname": args.dbname,
        "ollama_host": args.ollama_host,
        "embed_model": args.embed_model,
        "limit": args.limit
    }

    app.run(host='0.0.0.0', port=args.web_port, debug=False)

if __name__ == '__main__':
    main()
